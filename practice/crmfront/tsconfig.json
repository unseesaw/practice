{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES6",
    "rootDir": "./scripts",
    "outDir": "./dist/scripts",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
    "sourceMap": true
  },
  "include": ["scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}